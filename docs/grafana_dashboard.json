          "legendFormat": "{{phase}} / {{participant}} / {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "id": 14,
      "title": "Payment Operations & Open Staged Tx",
      "description": "Open staged payment transactions should normally sit at 0 in a healthy fast 2PC flow. A sustained nonzero value means prepared payments are waiting for Commit/Abort.",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(payment_operations_total[1m])) by (operation, result)",
          "legendFormat": "{{operation}} / {{result}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "payment_staged_transactions",
          "legendFormat": "open staged payment txs (0 healthy)",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "id": 15,
