        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(suggestions_operations_total[1m])) by (operation, result)",
          "legendFormat": "S {{operation}} / {{result}}",
          "refId": "C"
        }
      ]
