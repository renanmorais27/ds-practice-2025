          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(verification_operations_total[1m])) by (operation, result)",
          "legendFormat": "TV {{operation}} / {{result}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(fraud_operations_total[1m])) by (operation, result)",
          "legendFormat": "FD {{operation}} / {{result}}",
